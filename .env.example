# ---- Next.js (web) ----
# URL du backend FastAPI (exposée au navigateur via NEXT_PUBLIC_)
NEXT_PUBLIC_CONVERTER_URL=http://127.0.0.1:8000
CONVERTER_URL=http://127.0.0.1:8000

# ---- FastAPI converter service (services/converter/.env ou ici) ----
CONV_STORAGE_DIR=
CONV_RETENTION_SECONDS=3600
CONV_CORS_ORIGINS=http://localhost:3000
CONV_MAX_FILE_SIZE=2147483648
# Rate-limit par IP pour /convert et /operations (format slowapi : "30/minute")
CONV_RATE_LIMIT=30/minute
